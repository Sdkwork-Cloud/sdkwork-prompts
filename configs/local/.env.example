# Prompts local development configuration
# Copy to .env.local and adjust values for your environment

# Database (sdkwork-database lifecycle)
SDKWORK_PROMPTS_DATABASE_URL=postgresql://prompts:prompts@127.0.0.1:5432/prompts?sslmode=disable

# Optional integrations (unset = in-process no-op / log-only)
SDKWORK_PROMPTS_SEARCH_URL=
SDKWORK_PROMPTS_SEARCH_INDEX_ID=prompts
SDKWORK_PROMPTS_DRIVE_URL=
SDKWORK_PROMPTS_NOTIFICATION_URL=
SDKWORK_PROMPTS_INTEGRATION_LOG=true

# Logging
RUST_LOG=debug

# HTTP server
SDKWORK_PROMPTS_SERVER_PORT=8080
SDKWORK_PROMPTS_SERVER_HOST=0.0.0.0

# Default request context when IAM is disabled (local dev only)
SDKWORK_PROMPTS_DEFAULT_TENANT_ID=100001
SDKWORK_PROMPTS_DEFAULT_ORGANIZATION_ID=0
SDKWORK_PROMPTS_DEFAULT_USER_ID=1

# IAM session resolution (dual-token)
SDKWORK_PROMPTS_IAM_ENABLED=false
SDKWORK_PROMPTS_IAM_DATABASE_URL=
SDKWORK_PROMPTS_IAM_STRICT=false

# Require Authorization + Access-Token on app/backend prompts routes
SDKWORK_PROMPTS_REQUIRE_AUTH=false
