# Prompts Local Development Configuration
# Copy to .env.local and adjust values for your local environment

# Database
SDKWORK_CLAW_DATABASE_URL=postgresql://sdkwork_ai_dev:sdkworkdev123@127.0.0.1:5432/sdkwork_ai_dev?sslmode=disable

# Search (sdkwork-search-backend-api gateway or service root)
SDKWORK_PROMPTS_SEARCH_URL=http://localhost:8080
SDKWORK_PROMPTS_SEARCH_INDEX_ID=forum

# Private bootstrap access token for protected search backend-api calls.
SDKWORK_ACCESS_TOKEN=

# Notifications (optional HTTP adapter)
SDKWORK_PROMPTS_NOTIFICATION_URL=

# Drive
SDKWORK_PROMPTS_DRIVE_URL=http://localhost:8080

# Log integration port calls when external URLs are unset
SDKWORK_PROMPTS_INTEGRATION_LOG=true

# Logging
RUST_LOG=debug

# Server
SDKWORK_PROMPTS_SERVER_PORT=8080
SDKWORK_PROMPTS_SERVER_HOST=0.0.0.0

# Default request context when IAM headers are absent (local dev only)
SDKWORK_PROMPTS_DEFAULT_TENANT_ID=1
SDKWORK_PROMPTS_DEFAULT_ORGANIZATION_ID=0
SDKWORK_PROMPTS_DEFAULT_USER_ID=1

# IAM session resolution from dual tokens (uses forum DB unless IAM URL is set)
SDKWORK_PROMPTS_IAM_ENABLED=false
SDKWORK_PROMPTS_IAM_DATABASE_URL=
SDKWORK_PROMPTS_IAM_STRICT=false

# Require Authorization + Access-Token on app/backend forum routes
SDKWORK_PROMPTS_REQUIRE_AUTH=false

# Worker
SDKWORK_PROMPTS_WORKER_CONCURRENCY=4
SDKWORK_PROMPTS_WORKER_POLL_INTERVAL_MS=5000
