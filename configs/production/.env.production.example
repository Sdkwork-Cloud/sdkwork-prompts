# Prompts production configuration
# DO NOT commit secrets. Use your secret manager references.

# SDKWORK_PROMPTS_DATABASE_URL=<secret:prompts/database-url>
# SDKWORK_PROMPTS_SEARCH_URL=<secret:prompts/search-url>
# SDKWORK_PROMPTS_DRIVE_URL=<secret:prompts/drive-url>

RUST_LOG=info

SDKWORK_PROMPTS_SERVER_PORT=8080
SDKWORK_PROMPTS_SERVER_HOST=0.0.0.0

SDKWORK_PROMPTS_IAM_ENABLED=true
SDKWORK_PROMPTS_IAM_STRICT=true
SDKWORK_PROMPTS_REQUIRE_AUTH=true

SDKWORK_PROMPTS_DEFAULT_TENANT_ID=100001
SDKWORK_PROMPTS_DEFAULT_ORGANIZATION_ID=0
