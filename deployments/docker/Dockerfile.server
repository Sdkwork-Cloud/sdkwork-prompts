FROM rust:1.77-slim as builder

WORKDIR /app
COPY Cargo.toml Cargo.lock ./
COPY crates/ crates/

RUN cargo build --release --bin sdkwork-prompts-api-server || cargo build --release --lib

FROM debian:bookworm-slim
RUN apt-get update && apt-get install -y ca-certificates && rm -rf /var/lib/apt/lists/*

WORKDIR /app
COPY --from=builder /app/target/release/ ./

EXPOSE 8080

ENV RUST_LOG=info
ENV SDKWORK_PROMPTS_DATABASE_URL=postgres://localhost:5432/forum

CMD ["./sdkwork-prompts-api-server"]
