{
  "schemaVersion": 1,
  "kind": "sdkwork.route.manifest",
  "packageName": "sdkwork-routes-prompts-backend-api",
  "surface": "backend-api",
  "owner": "sdkwork-prompts",
  "domain": "intelligence",
  "capability": "prompts",
  "apiAuthority": "sdkwork-prompts-backend-api",
  "sdkFamily": "sdkwork-prompts-backend-sdk",
  "prefix": "/backend/v3/api",
  "routes": [
    { "method": "GET", "path": "/backend/v3/api/prompts", "operationId": "prompts.admin.definitions.list", "auth": { "mode": "dual-token" } },
    { "method": "POST", "path": "/backend/v3/api/prompts", "operationId": "prompts.admin.definitions.create", "auth": { "mode": "dual-token" } },
    { "method": "GET", "path": "/backend/v3/api/prompts/{promptId}/versions", "operationId": "prompts.admin.versions.list", "auth": { "mode": "dual-token" } },
    { "method": "POST", "path": "/backend/v3/api/prompts/{promptId}/versions", "operationId": "prompts.admin.versions.create", "auth": { "mode": "dual-token" } },
    { "method": "POST", "path": "/backend/v3/api/prompts/versions/{versionId}/publish", "operationId": "prompts.admin.versions.publish", "auth": { "mode": "dual-token" } },
    { "method": "POST", "path": "/backend/v3/api/prompts/versions/{versionId}/render", "operationId": "prompts.admin.versions.render", "auth": { "mode": "dual-token" } },
    { "method": "GET", "path": "/backend/v3/api/prompts/{promptId}/bindings", "operationId": "prompts.admin.bindings.list", "auth": { "mode": "dual-token" } },
    { "method": "POST", "path": "/backend/v3/api/prompts/{promptId}/bindings", "operationId": "prompts.admin.bindings.create", "auth": { "mode": "dual-token" } },
    { "method": "PUT", "path": "/backend/v3/api/prompts/bindings/{bindingId}", "operationId": "prompts.admin.bindings.update", "auth": { "mode": "dual-token" } }
  ]
}
