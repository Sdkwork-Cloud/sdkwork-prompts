              "format": "int64",
              "pattern": "^[1-9][0-9]*$",
              "type": "string",
              "x-sdkwork-int64-string": true,
              "x-sdkwork-rust-type": "i64"
            }
          },
          {
            "description": "Page size query parameter.",
            "in": "query",
            "name": "page_size",
            "required": false,
            "schema": {
              "format": "int64",
              "pattern": "^[1-9][0-9]*$",
              "type": "string",
