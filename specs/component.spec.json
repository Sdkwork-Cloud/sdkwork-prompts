  "integration": {
    "authority": "Root SDKWork specs remain authoritative. Local specs may extend but must not contradict them.",
    "dependencyPolicy": "Prompts integrates appbase, Drive, search, messaging, and notification capabilities only through declared SDK dependencies or service ports.",
    "sdkPolicy": "Frontend and app clients consume generated SDKs or approved composed wrappers; no raw HTTP or manual auth headers.",
    "languagePolicy": "Rust crates expose service and route boundaries; generated TypeScript SDK output remains under sdks."
  },
  "verification": {
    "commands": [
      "node tests/static/prompts-contract-boundary.test.mjs",
      "node tools/validators/validate_prm_contracts.mjs"
    ]
