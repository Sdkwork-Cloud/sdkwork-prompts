        "workspace": "sdkwork-appbase",
        "sdkFamily": "sdkwork-iam-app-sdk",
        "apiAuthority": "sdkwork-iam-app-api",
        "surface": "app-api",
        "apiPrefix": "/app/v3/api",
        "runtimeMode": "dependency-sdk"
      }
